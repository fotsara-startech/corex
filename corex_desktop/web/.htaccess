# Flutter Web - Configuration Apache

# MIME types pour Flutter
AddType application/javascript .js
AddType application/wasm .wasm
AddType application/octet-stream .bin

# Désactiver la compression Apache pour les fichiers déjà compressés
<IfModule mod_deflate.c>
  SetEnvIfNoCase Request_URI \.wasm$ no-gzip dont-vary
</IfModule>

# Headers pour les fichiers WASM
<FilesMatch "\.wasm$">
  Header set Content-Type "application/wasm"
</FilesMatch>

# Cache pour les assets statiques
<FilesMatch "\.(js|css|png|jpg|gif|ico|woff|woff2|ttf|otf)$">
  Header set Cache-Control "max-age=31536000, public"
</FilesMatch>

# Pas de cache pour index.html
<FilesMatch "index\.html$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>

# Rediriger toutes les routes vers index.html (SPA)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)$ /index.html [L,QSA]
</IfModule>
